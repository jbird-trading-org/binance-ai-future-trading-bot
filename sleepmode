#!/bin/bash
# Sleep Mode Toggle — sets SLEEP_MODE in .env
# Usage: ./sleepmode on | ./sleepmode off

DIR="$(cd "$(dirname "$0")" && pwd)"
ENV_FILE="$DIR/.env"

case "$1" in
  on)
    grep -q '^SLEEP_MODE=' "$ENV_FILE" 2>/dev/null && \
      sed -i 's/^SLEEP_MODE=.*/SLEEP_MODE=true/' "$ENV_FILE" || \
      echo 'SLEEP_MODE=true' >> "$ENV_FILE"
    echo "✅ Sleep Mode ON"
    ;;
  off)
    grep -q '^SLEEP_MODE=' "$ENV_FILE" 2>/dev/null && \
      sed -i 's/^SLEEP_MODE=.*/SLEEP_MODE=false/' "$ENV_FILE" || \
      echo 'SLEEP_MODE=false' >> "$ENV_FILE"
    echo "✅ Sleep Mode OFF"
    ;;
  *)
    echo "Usage: ./sleepmode on | ./sleepmode off"
    exit 1
    ;;
esac

systemctl restart neko-scanner 2>/dev/null || echo "Restart scanner: npm run start:scanner"
