# Binance API (REQUIRED)
BINANCE_API_KEY=your_api_key_here
BINANCE_SECRET=your_secret_here

# Telegram (REQUIRED - you must provide your own)
# Get bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHANNEL=your_channel_id_here

# Brave Search (REQUIRED for news - get free key at brave.com/search/api)
BRAVE_API_KEY=your_b...here

# OpenRouter (for LLM analysis gate — get key at openrouter.ai)
OPENROUTER_API_KEY=your_openrouter_key_here

# Redis (optional — enables shared cache and pub/sub across services)
# REDIS_ENABLED=true
# REDIS_URL=redis://127.0.0.1:6379
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379
# REDIS_DB=0
# REDIS_KEY_PREFIX=neko
